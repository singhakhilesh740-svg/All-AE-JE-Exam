rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isLoggedIn()
        && request.auth.token.email == '112ce0489@gmail.com';
    }

    // ── Questions ──────────────────────────────────────────────────────────
    // Any logged-in user can read; only admin can write.
    match /exams/{examId}/questions/{questionId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }
    match /exams/{examId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Notes ──────────────────────────────────────────────────────────────
    match /notes/{subjectId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // READ: any logged-in user can read user docs. Required so the Google-login
    //   merge query (where('email','==',...)) works. Trade-off: a logged-in user
    //   could read other users' name/email/mobile. Acceptable here; tighten later.
    // WRITE: only the owner can write their own doc.
    match /users/{userId} {
      allow read:  if isLoggedIn();
      allow write: if isOwner(userId);

      // Subcollections (attempts, bookmarks) — owner only.
      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }


    // ── Reports ────────────────────────────────────────────────────────────
    // Any logged-in user can create a report; only admin can read/update/delete.
    match /reports/{reportId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Feedback ──────────────────────────────────────────────────────────
    // Any logged-in user can submit feedback; only admin can read/manage.
    match /feedback/{feedbackId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
