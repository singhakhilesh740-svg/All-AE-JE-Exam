rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == '112ce0489@gmail.com';
    }

    // Questions: any logged-in user can read, only admin writes
    match /exams/{examId}/questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Notes: any logged-in user can read, only admin writes
    match /notes/{subjectId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // User profile: only the owner (matched by phone-auth UID) can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollections (attempts, bookmarks)
      match /{subCollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
